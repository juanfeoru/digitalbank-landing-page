---
import FeatureCard from "../components/features/FeatureCard.astro";
import { features } from "../data/features";
---

<section class="bg-gray-100 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center lg:text-left mb-12 lg:mb-16">
      <h2 class="text-blue-950 text-4xl lg:text-5xl mb-6">Why choose Easybank?</h2>
      <p class="text-gray-600 text-sm lg:text-base lg:max-w-2xl text-balance">
        We leverage Open Banking to turn your bank account into your financial hub. Control
        your finances like never before.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      {
        features.map((feature) => (
          <FeatureCard {...feature} />
        ))
      }
    </div>
  </div>
</section>